{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "scripts/prepare-fiber.sh && cargo build --release -p lspd && cd demo-ui && npm install"
  },
  "deploy": {
    "startCommand": "scripts/railway-demo-start.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
